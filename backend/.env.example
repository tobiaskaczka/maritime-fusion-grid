# Comma-separated frontend origins allowed to call this API from a browser.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional: enables Global Fishing Watch fishing effort and SAR vessel tiles.
# Request a token from https://globalfishingwatch.org/our-apis/
GFW_API_TOKEN=
GFW_AIS_DATASET=public-global-fishing-effort:latest
GFW_SAR_DATASET=public-global-sar-presence:latest
GFW_DATE_RANGE=2026-01-01,2026-06-01
